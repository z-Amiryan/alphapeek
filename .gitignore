# Dependencies
node_modules/
.pnpm-store/

# This is a pnpm-only workspace (see packageManager in package.json). A stray
# npm/yarn lockfile splits the dependency source of truth and confuses CI.
package-lock.json
yarn.lock

# Build output
dist/
.output/
.wxt/
*.tsbuildinfo

# Env / secrets — NEVER commit
.env
.env.*
!.env.example
.dev.vars
.wrangler/

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# Local agent / tooling config (never commit)
.claude/settings.local.json
*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test / coverage
coverage/

# Generated store-visuals capture output (regenerate via the store-visuals app)
apps/store-visuals/export/
.tmp-shots/
