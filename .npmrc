# Enforce the Node version declared in package.json "engines" (>=22) at install
# time, so a too-old Node fails fast instead of breaking mid-build.
min-release-age=3
engine-strict=true
save-exact=true

# NOTE: do not set `node-linker=hoisted` here — in this pnpm workspace it breaks
# per-package binary resolution (wxt/tsc/vitest/wrangler "cannot find module").
# The WXT "./internal" error is a dependency-version conflict, not a linker issue
# (see the React plugin pin in package.json), so the default isolated linker stays.
