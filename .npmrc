# Enforce the Node version declared in package.json "engines" (>=22) at install
# time, so a too-old Node fails fast instead of breaking mid-build.
engine-strict=true

# Pin exact versions on `pnpm add` (no caret ranges) so package.json matches the
# lockfile and upgrades are always explicit.
save-exact=true

# Supply-chain cooldown: refuse to install a package version younger than this,
# so a freshly-published compromised release can't land before it's caught. The
# value is in MINUTES — 4320 = 3 days. NOTE: requires pnpm >= 10.16; we're pinned
# to pnpm@9.12.0 (package.json "packageManager"), so this is inert until that
# toolchain bump. Do not rename to `min-release-age` — pnpm silently ignores that.
minimum-release-age=4320

# NOTE: do not set `node-linker=hoisted` here — in this pnpm workspace it breaks
# per-package binary resolution (wxt/tsc/vitest/wrangler "cannot find module").
# The WXT "./internal" error is a dependency-version conflict, not a linker issue
# (see the React plugin pin in package.json), so the default isolated linker stays.
